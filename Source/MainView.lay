                <button data-base="AButton" data-class="AButton" class="AButton-Style" style="width: 100px; position: relative; left: 0px; top: calc(50% - 20px); height: 40px; margin-top: 0px; background-color: rgb(0, 186, 255); color: rgb(255, 255, 255);" data-center-y="true" id="" data-listener-click="MainView:click_edit_ok">수정</button>
                <button data-base="AButton" data-class="AButton" class="AButton-Style" style="width: 100px; position: relative; left: 0px; top: calc(50% - 20px); margin-left: 10px; height: 40px; background-color: rgb(0, 186, 255); color: rgb(255, 255, 255);" data-center-y="true" id="" data-listener-click="MainView:click_edit_delete">삭제</button>
            </div>
        </div>
    </div>
</div>